import { NextResponse, type NextRequest } from 'next/server';
import { createServerClient, type CookieOptions } from '@supabase/ssr';

export async function middleware(request: NextRequest) {
    let response = NextResponse.next({ request });

    // Securely initialize Supabase client for edge middleware
    const supabase = createServerClient(
        process.env.NEXT_PUBLIC_SUPABASE_URL!,
        process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
        {
            cookies: {
                get(name: string) { return request.cookies.get(name)?.value; },
                set(name: string, value: string, options: CookieOptions) {
                    request.cookies.set({ name, value, ...options });
                    response.cookies.set({ name, value, ...options });
                },
                remove(name: string, options: CookieOptions) {
                    request.cookies.set({ name, value: '', ...options });
                    response.cookies.set({ name, value: '', ...options });
                },
            },
        }
    );

    // Verify current session
    const { data: { session } } = await supabase.auth.getSession();

    console.log(`Middleware: ${request.nextUrl.pathname}, Session: ${!!session}`);

    // 1. API Route Protection (e.g., Cart needs authentication)
    if (request.nextUrl.pathname.startsWith('/api/cart') && !session) {
        return NextResponse.json({ error: 'Non autorisé' }, { status: 401 });
    }

    // 2. Admin Dashboard Protection
    if (request.nextUrl.pathname.startsWith('/admin')) {
        if (!session) {
            // Check if /login exists before redirecting, otherwise it might 404
            return NextResponse.redirect(new URL('/login', request.url));
        }

        // Check for Admin role OR specific Admin Email for bypass
        const role = session.user.user_metadata?.role;
        const isAdminEmail = session.user.email === 'ElectroMart123@gmail.com';

        if (role !== 'admin' && !isAdminEmail) {
            // Redirect non-admins away from admin panel
            return NextResponse.redirect(new URL('/', request.url));
        }
    }

    return response;
}

export const config = {
    matcher: ['/admin/:path*', '/api/cart/:path*'],
};
